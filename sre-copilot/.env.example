# Google Cloud (Agent Builder backend)
GCP_PROJECT_ID=your-gcp-project-id
REGION=us-central1
# Point to your service account key for local dev (in Cloud Run this is automatic)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# Dynatrace (MCP partner integration)
DYNATRACE_URL=https://XXXXXXXX.apps.dynatrace.com
DT_CLIENT_ID=dt0s02.XXXXXXXXX
DT_CLIENT_SECRET=dt0s02.XXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DT_ACCOUNT_URN=urn:dtaccount:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# GitLab
GITLAB_TOKEN=glpat-XXXXXXXXX
GITLAB_PROJECT_ID=XXXXXXX

# Approval UI backend URL
APPROVAL_WEBHOOK_URL=https://your-mttr-cloudrun-url.run.app
WEBHOOK_URL=https://your-sre-webhook-cloudrun-url.run.app
PAYMENT_SERVICE_URL=https://your-payment-service-cloudrun-url.run.app

# ── Frontend / approval app (frontend/server.py) ──────────────────────────────
# Public URL of the approval app — used for Slack OAuth redirect + button links.
APP_URL=https://your-spark-cloudrun-url.run.app

# Slack — shared/fallback workspace (optional; tenants can also connect their own).
SLACK_BOT_TOKEN=xoxb-XXXXXXXX
SLACK_CHANNEL_ID=CXXXXXXXX
SLACK_SIGNING_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Slack "Add to Slack" OAuth (optional — enables one-click connect in the wizard).
# Register the redirect URL ${APP_URL}/slack/oauth/callback in your Slack app.
SLACK_CLIENT_ID=XXXXXXXXXXXX.XXXXXXXXXXXX
SLACK_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# SLACK_OAUTH_SCOPES=chat:write,channels:read,groups:read   # default shown

# Session persistence + token encryption (both optional, degrade gracefully).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENC_KEY=
# Set to 1 to store sessions in Firestore instead of in-memory (needs Firestore API + datastore.user).
FIRESTORE_SESSIONS=0
# FIRESTORE_COLLECTION=spark_sessions                       # default shown
