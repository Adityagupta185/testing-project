# Google Cloud (Agent Builder backend)
GCP_PROJECT_ID=your-gcp-project-id
REGION=us-central1
# Point to your service account key for local dev (in Cloud Run this is automatic)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# Dynatrace (MCP partner integration)
DYNATRACE_URL=https://XXXXXXXX.apps.dynatrace.com
DT_CLIENT_ID=dt0s02.XXXXXXXXX
DT_CLIENT_SECRET=dt0s02.XXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DT_ACCOUNT_URN=urn:dtaccount:XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# GitLab
GITLAB_TOKEN=glpat-XXXXXXXXX
GITLAB_PROJECT_ID=XXXXXXX

# Approval UI backend URL
APPROVAL_WEBHOOK_URL=https://your-mttr-cloudrun-url.run.app
WEBHOOK_URL=https://your-sre-webhook-cloudrun-url.run.app
PAYMENT_SERVICE_URL=https://your-payment-service-cloudrun-url.run.app
